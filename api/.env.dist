APP_ENV=prod
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1|192\.168\.178\.35|kaderblick\.byte-artist\.de|staging\.kaderblick\.de|demo(_[a-z0-9]+)?\.kaderblick\.de|kaderblick\.de)(:[0-9]+)?$'
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
MESSENGER_TRANSPORT_DSN=amqp://kaderblick:kaderblick@kaderblick-rabbitmq:5672/%2f
MAILER_FROM="no-reply@kaderblick.de"
# E-Mail-Adresse des Admins für proaktive Fehler- und Sicherheits-Benachrichtigungen
ADMIN_ALERT_EMAIL="admin@kaderblick.de"
GOOGLE_REDIRECT_URI=https://kaderblick.de/oauth2callback
GITHUB_REPO_OWNER=mastercad
GITHUB_REPO_NAME=kaderblick
GITHUB_TOKEN=
DEMO_WEBHOOK_SECRET=
FUSSBALLDE_BASE_URL=https://www.fussball.de
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
FRONTEND_URL=https://kaderblick.de

# Stripe Billing (zunächst leer lassen; die globale Testphase verhindert Abbuchungen)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
DEMO_URL=https://demo.kaderblick.de
###> player documents ###
# Verpflichtender privater Drive-Ordner für Spielerdokumente (nicht den ggf. geteilten Video-Ordner verwenden).
GOOGLE_CREDENTIALS_JSON=config/google/kaderblick-worker.json
GOOGLE_DOCUMENTS_FOLDER_ID=
# Temporäres, privates S3-kompatibles Staging (z. B. MinIO oder AWS S3).
DOCUMENT_STAGING_ENDPOINT=http://kaderblick-minio:9000
DOCUMENT_STAGING_REGION=eu-central-1
DOCUMENT_STAGING_BUCKET=kaderblick-documents-staging
DOCUMENT_STAGING_ACCESS_KEY=kaderblick
DOCUMENT_STAGING_SECRET_KEY=change-me
DOCUMENT_STAGING_PATH_STYLE=true
# Optional, für AWS S3 typischerweise AES256; bei MinIO ohne KMS leer lassen.
DOCUMENT_STAGING_SSE=
###< player documents ###
