<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ news.title }} | Kaderblick Aktuelles</title>
    <meta name="description" content="{{ description }}">
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
    <link rel="canonical" href="{{ canonicalUrl }}">
    <meta property="og:site_name" content="Kaderblick">
    <meta property="og:locale" content="de_DE">
    <meta property="og:type" content="article">
    <meta property="og:title" content="{{ news.title }} | Kaderblick Aktuelles">
    <meta property="og:description" content="{{ description }}">
    <meta property="og:url" content="{{ canonicalUrl }}">
    <meta property="og:image" content="{{ absolute_url('/images/share_bg.jpg') }}">
    <meta property="og:image:secure_url" content="{{ absolute_url('/images/share_bg.jpg') }}">
    <meta property="og:image:type" content="image/jpeg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="{{ news.title }}">
    <meta property="article:published_time" content="{{ news.createdAt|date('c') }}">
    <meta property="article:modified_time" content="{{ (news.updatedAt ?? news.createdAt)|date('c') }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@kaderblick">
    <meta name="twitter:creator" content="@kaderblick">
    <meta name="twitter:title" content="{{ news.title }} | Kaderblick Aktuelles">
    <meta name="twitter:description" content="{{ description }}">
    <meta name="twitter:image" content="{{ absolute_url('/images/share_bg.jpg') }}">
    <meta name="twitter:image:alt" content="{{ news.title }}">
    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "Article",
            "headline": {{ (news.title ~ ' | Kaderblick Aktuelles')|json_encode|raw }},
            "description": {{ description|json_encode|raw }},
            "datePublished": {{ news.createdAt|date('c')|json_encode|raw }},
            "dateModified": {{ (news.updatedAt ?? news.createdAt)|date('c')|json_encode|raw }},
            "author": {
                "@type": "Person",
                "name": {{ (news.createdBy.firstName ~ ' ' ~ news.createdBy.lastName)|trim|json_encode|raw }}
            },
            "publisher": {
                "@type": "Organization",
                "name": "Kaderblick",
                "logo": {
                    "@type": "ImageObject",
                    "url": {{ absolute_url('/images/kaderblick_website_appicon.png')|json_encode|raw }}
                }
            },
            "mainEntityOfPage": {{ canonicalUrl|json_encode|raw }}
        }
    </script>
    <style>
        :root {
            color-scheme: light;
            font-family: Inter, system-ui, sans-serif;
            line-height: 1.72;
            color: #17301a;
            background: linear-gradient(180deg, #f5f8f1 0%, #ffffff 40%);
        }
        * { box-sizing: border-box; }
        body { margin: 0; color: #17301a; }
        a { color: #056d13; text-decoration: none; }
        a:hover { text-decoration: underline; }
        .shell { max-width: 940px; margin: 0 auto; padding: 0 24px; }
        header { padding: 28px 0 8px; }
        nav { display: flex; flex-wrap: wrap; gap: 16px; font-weight: 600; }
        article { padding: 38px 0 80px; }
        .meta { font-size: 0.95rem; color: #5d6f61; margin-bottom: 18px; }
        h1 { font-size: clamp(2.2rem, 5vw, 4.1rem); line-height: 1.02; margin: 0 0 24px; }
        .intro { font-size: 1.08rem; color: #4b6150; margin-bottom: 28px; }
        .content { background: rgba(255,255,255,0.96); border: 1px solid #d9e4d4; border-radius: 24px; padding: 28px; box-shadow: 0 12px 36px rgba(23, 48, 26, 0.08); }
        .content img { max-width: 100%; height: auto; border-radius: 16px; }
        .content h2, .content h3 { line-height: 1.2; }
        .back { display: inline-flex; margin-top: 18px; font-weight: 700; }
    </style>
</head>
<body>
    <header class="shell">
        <nav aria-label="Public navigation">
            <a href="/">Startseite</a>
            <a href="/funktionen">Funktionen</a>
            <a href="/aktuelles">Aktuelles</a>
            <a href="/für-trainer">Für Trainer</a>
            <a href="/für-eltern">Für Eltern</a>
            <a href="/für-jugendleitung">Für Jugendleitung</a>
            <a href="/spielanalyse-software">Spielanalyse</a>
            <a href="/kontakt">Kontakt</a>
        </nav>
    </header>
    <main class="shell">
        <article>
            <p class="meta">{{ news.createdAt|date('d.m.Y') }} · {{ news.createdBy.firstName }} {{ news.createdBy.lastName }}</p>
            <h1>{{ news.title }}</h1>
            <p class="intro">{{ description }}</p>
            <div class="content">{{ news.content|raw }}</div>
            <a class="back" href="{{ path('public_news_index') }}">Zurück zur Übersicht</a>
        </article>
    </main>
</body>
</html>