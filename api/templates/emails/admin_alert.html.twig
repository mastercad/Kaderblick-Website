<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 660px; margin: 0 auto; padding: 20px; }
        .header { padding: 20px; text-align: center; border-radius: 5px 5px 0 0; color: white; background-color: {{ color ?? '#1a4789' }}; }
        .header h1 { margin: 0; font-size: 20px; }
        .content { background-color: #ffffff; padding: 20px; border: 1px solid #ddd; border-radius: 0 0 5px 5px; }
        table.details { width: 100%; border-collapse: collapse; margin-top: 12px; }
        table.details th { text-align: left; padding: 8px 10px; background: #f5f5f5; border: 1px solid #ddd; width: 35%; font-weight: bold; }
        table.details td { padding: 8px 10px; border: 1px solid #ddd; word-break: break-all; }
        .trace { background: #1e1e1e; color: #d4d4d4; padding: 12px; font-size: 11px; font-family: monospace; border-radius: 4px; overflow-x: auto; white-space: pre-wrap; margin-top: 16px; max-height: 400px; overflow-y: auto; }
        .badge { display: inline-block; padding: 2px 8px; border-radius: 3px; font-size: 12px; font-weight: bold; color: white; background-color: {{ color ?? '#1a4789' }}; }
        .footer { text-align: center; margin-top: 20px; padding: 10px; font-size: 12px; color: #999; }
    </style>
</head>
<body>
    <div class="header">
        <h1>{{ icon ?? '⚠️' }} {{ headline ?? 'Admin-Benachrichtigung' }}</h1>
    </div>

    <div class="content">
        <p><span class="badge">{{ type|upper|replace({'_': ' '}) }}</span> &nbsp; {{ timestamp }}</p>

        {% if details is defined and details %}
            <table class="details">
                {% for label, value in details %}
                    <tr>
                        <th>{{ label }}</th>
                        <td>{{ value }}</td>
                    </tr>
                {% endfor %}
            </table>
        {% endif %}

        {% if trace %}
            <p><strong>Stack Trace:</strong></p>
            <div class="trace">{{ trace }}</div>
        {% endif %}
    </div>

    <div class="footer">
        {{ website_name ?? 'Kaderblick' }} Admin-Alert &mdash; {{ current_year }}<br>
        Diese E-Mail wurde automatisch generiert.
    </div>
</body>
</html>
