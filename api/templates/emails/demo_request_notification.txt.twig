{% extends 'emails/base.txt.twig' %}

{% block title %}Neue Demo-Anfrage von {{ demoRequest.name }}{% endblock %}

{% block content %}
Hallo,

eine neue Demo-Anfrage ist eingegangen:

Name:    {{ demoRequest.name }}
E-Mail:  {{ demoRequest.email }}
{% if demoRequest.phone %}Telefon: {{ demoRequest.phone }}
{% endif %}{% if demoRequest.clubName %}Verein:  {{ demoRequest.clubName }}
{% endif %}{% if demoRequest.league %}Liga:    {{ demoRequest.league }}
{% endif %}{% if demoRequest.ageGroup %}Altersgruppe / Team: {{ demoRequest.ageGroup }}
