<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kaderblick – Poster</title>

    {# ── Open Graph (WhatsApp, Facebook, iMessage …) ──────────────────────── #}
    <meta property="og:type"              content="website" />
    <meta property="og:site_name"         content="Kaderblick" />
    <meta property="og:title"             content="Kaderblick Poster" />
    <meta property="og:description"       content="Schaut mal unser Poster an!" />
    <meta property="og:image"             content="{{ app.request.schemeAndHttpHost }}/uploads/poster-share/{{ filename }}" />
    <meta property="og:image:type"        content="image/png" />
    <meta property="og:image:width"       content="1080" />
    <meta property="og:image:height"      content="1080" />
    <meta property="og:image:alt"         content="Kaderblick Poster" />
    <meta property="og:url"              content="{{ app.request.schemeAndHttpHost }}/poster-share/{{ filename }}" />

    {# ── Twitter / X Card ────────────────────────────────────────────────── #}
    <meta name="twitter:card"             content="summary_large_image" />
    <meta name="twitter:title"            content="Kaderblick Poster" />
    <meta name="twitter:description"      content="Schaut mal unser Poster an!" />
    <meta name="twitter:image"            content="{{ app.request.schemeAndHttpHost }}/uploads/poster-share/{{ filename }}" />
    <meta name="twitter:image:alt"        content="Kaderblick Poster" />

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: system-ui, -apple-system, sans-serif;
            background: #0f0f1a;
            color: #e0e0f0;
            min-height: 100dvh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
            text-align: center;
            gap: 1.25rem;
        }

        img {
            max-width: min(480px, 100%);
            border-radius: 16px;
            box-shadow: 0 8px 32px rgba(0,0,0,.5);
        }

        p {
            font-size: 1rem;
            opacity: .7;
            max-width: 360px;
        }

        small {
            font-size: .75rem;
            opacity: .4;
        }
    </style>
</head>
<body>
    <img src="/uploads/poster-share/{{ filename }}"
         alt="Kaderblick Poster"
         loading="eager" />

    <p>Schaut mal unser Poster an!</p>
    <small>Erstellt mit Kaderblick</small>
</body>
</html>
