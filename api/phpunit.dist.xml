<?xml version="1.0" encoding="UTF-8"?>
<!-- https://phpunit.readthedocs.io/en/latest/configuration.html -->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         colors="true"
         failOnDeprecation="false"
         failOnNotice="false"
         failOnWarning="false"
         bootstrap="tests/bootstrap.php"
         cacheDirectory=".phpunit.cache"
         testdox="false"
         displayDetailsOnTestsThatTriggerDeprecations="true"
         displayDetailsOnTestsThatTriggerNotices="true"
         displayDetailsOnTestsThatTriggerWarnings="true"
>
    <php>
        <ini name="display_errors" value="1" />
        <ini name="error_reporting" value="-1" />
        <server name="APP_ENV" value="test" force="true" />
        <server name="SHELL_VERBOSITY" value="-1" />
    </php>

    <testsuites>
        <testsuite name="Project Test Suite">
            <directory>tests</directory>
        </testsuite>
    </testsuites>

    <source ignoreSuppressionOfDeprecations="true"
            ignoreIndirectDeprecations="true"
            restrictNotices="true"
            restrictWarnings="true"
    >
        <include>
            <directory>src</directory>
        </include>

        <exclude>
            <directory>src/DataFixtures</directory>
            <directory>src/Repository</directory>
            <directory>src/Entity</directory>

            <!-- Symfony form type definitions – pure configuration, no testable logic -->
            <directory>src/Form</directory>

            <!-- Doctrine custom infrastructure – framework-level, not unit-testable -->
            <directory>src/Doctrine</directory>

            <!-- Framework bootstrap -->
            <file>src/Kernel.php</file>

            <!-- External service adapters – wrap external APIs, no business logic -->
            <directory>src/Adapter</directory>

            <!-- Dev/utility CLI commands – no business logic worth unit-testing -->
            <file>src/Command/GenerateFakeGameEventsCommand.php</file>
            <file>src/Command/GenerateVapidKeysCommand.php</file>
            <file>src/Command/HashPasswordCommand.php</file>
            <file>src/Command/GoogleDriveAuthCommand.php</file>
            <file>src/Command/MigrationDiffCommand.php</file>

            <!-- Simple DTOs / value objects with no logic -->
            <file>src/Dto/ContactMessageDto.php</file>

            <!-- PHP enums – pure data definitions, nothing to test regardless of existing coverage -->
            <directory>src/Enum</directory>

            <!-- JWT framework integration subscribers – test LexikJWT, not our logic -->
            <file>src/EventSubscriber/JWTExceptionSubscriber.php</file>
            <file>src/EventSubscriber/JWTExpiredSubscriber.php</file>
            <file>src/EventSubscriber/JWTLoginSubscriber.php</file>
            <file>src/EventSubscriber/JWTResponseSubscriber.php</file>

            <!-- Security framework glue – minimal/no business logic -->
            <file>src/Security/JwtEntryPoint.php</file>
            <file>src/Security/UserChecker.php</file>

            <!-- Symfony constraint annotation and validator – framework glue -->
            <directory>src/Validator</directory>

            <!-- Static/trivial one-liner controllers -->
            <file>src/Controller/ImprintController.php</file>
            <file>src/Controller/PrivacyController.php</file>

            <!-- Dev-only email preview controller -->
            <file>src/Controller/EmailPreviewController.php</file>
        </exclude>

        <deprecationTrigger>
            <method>Doctrine\Deprecations\Deprecation::trigger</method>
            <method>Doctrine\Deprecations\Deprecation::delegateTriggerToBackend</method>
            <function>trigger_deprecation</function>
        </deprecationTrigger>
    </source>

    <extensions>
    </extensions>
</phpunit>
